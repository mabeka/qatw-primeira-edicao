pipeline {
    agent {
        docker {
            image 'mabeka/playwright-java:1.58.2'
            args '--network qatw-primeira-edicao_skynet'
            alwaysPull true
        }
    }
    stages {
        stage('Deps') {
            steps {
                sh 'npm ci'
            }
        }
        stage('Tests') {
            steps {
                sh 'npx playwright test'
            }
        }
    }
}
